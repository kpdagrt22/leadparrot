# ---------------------------------------------------------------------------
# LeadParrot environment variables
# Copy this file to `.env.local` and fill in the values you have.
# Everything is OPTIONAL for local development: missing keys fall back to
# safe mock/demo behavior so you can run the full vertical slice offline.
# ---------------------------------------------------------------------------

# --- Supabase (Postgres + Auth + Storage + RLS) ----------------------------
# Without these the app runs in "demo" mode using in-memory mock data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI provider abstraction -----------------------------------------------
# AI_PROVIDER = mock | openai | anthropic   (default: mock)
# `mock` returns deterministic demo scoring/replies with no API calls.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Reddit (official API, optional) ---------------------------------------
# If missing, the Reddit source returns mock demo posts + setup instructions.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=leadparrot/0.1 by your_reddit_username

# --- Email digests (Resend, optional) --------------------------------------
# If missing, the daily digest is shown as an in-dashboard preview only.
RESEND_API_KEY=
# Preferred sender name. (Legacy DIGEST_FROM_EMAIL is still accepted.)
FROM_EMAIL=LeadParrot <digest@yourdomain.com>

# --- Stripe billing (optional) ---------------------------------------------
# If missing, billing UI shows "Billing not configured".
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs for each paid plan (create them in your Stripe dashboard).
NEXT_PUBLIC_STRIPE_PRICE_STARTER=
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_AGENCY=

# --- Source integrations (all OPTIONAL — placeholders in v1) ----------------
# LeadParrot does NOT scrape. These are reserved for OFFICIAL search APIs only.
# Without them, web-search sources show "requires API key" and return demo data.
TAVILY_API_KEY=
EXA_API_KEY=
SERPAPI_API_KEY=

# --- Notifications (optional) — alerts to the ACCOUNT OWNER only ------------
# Owner-only: every alert goes to the org's own verified email/number, about
# their own leads — never to a prospect. All channels degrade to in-app/console.
#
# Email — SMTP (nodemailer) preferred when set, then Resend, then console.
EMAIL_PROVIDER=            # smtp | resend | console  (blank = auto-detect)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false         # true for port 465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=The Leads Nest <alerts@theleadsnest.com>
# SMS — Twilio (alerts to the owner's verified phone)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=          # +1XXXXXXXXXX
# WhatsApp — Twilio WhatsApp OR Meta Cloud API (use one)
TWILIO_WHATSAPP_FROM=     # whatsapp:+14155238886
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAMESPACE=

# --- Background jobs + observability (optional) -----------------------------
# CRON_SECRET protects the daily-digest cron route (/api/cron/digest). The
# scheduler must send `Authorization: Bearer <CRON_SECRET>`. Vercel Cron sets
# this header automatically when CRON_SECRET is configured. Without it, the
# cron route refuses to run (503) so it can never be triggered anonymously.
CRON_SECRET=
# Optional error sink. If set, captured server errors are POSTed here as JSON
# (a collector, a Slack incoming webhook, etc.). Unset = structured logs only.
ERROR_WEBHOOK_URL=

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Comma-separated list of emails allowed to view the internal admin page.
ADMIN_EMAILS=
