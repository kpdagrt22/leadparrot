# ---------------------------------------------------------------------------
# LeadParrot environment variables
# Copy this file to `.env.local` and fill in the values you have.
# Everything is OPTIONAL for local development: missing keys fall back to
# safe mock/demo behavior so you can run the full vertical slice offline.
# ---------------------------------------------------------------------------

# --- Supabase (Postgres + Auth + Storage + RLS) ----------------------------
# Without these the app runs in "demo" mode using in-memory mock data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI provider abstraction -----------------------------------------------
# AI_PROVIDER = mock | openai | anthropic   (default: mock)
# `mock` returns deterministic demo scoring/replies with no API calls.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Reddit (official API, optional) ---------------------------------------
# If missing, the Reddit source returns mock demo posts + setup instructions.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=leadparrot/0.1 by your_reddit_username

# --- Email digests (Resend, optional) --------------------------------------
# If missing, the daily digest is shown as an in-dashboard preview only.
RESEND_API_KEY=
DIGEST_FROM_EMAIL=LeadParrot <digest@yourdomain.com>

# --- Stripe billing (optional) ---------------------------------------------
# If missing, billing UI shows "Billing not configured".
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs for each paid plan (create them in your Stripe dashboard).
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# --- Web search placeholder (future) ---------------------------------------
# Reserved for SerpAPI / Tavily / Exa / Bing integration. Not used in v1.
WEB_SEARCH_PROVIDER=
WEB_SEARCH_API_KEY=

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Comma-separated list of emails allowed to view the internal admin page.
ADMIN_EMAILS=
